# Supabase（必須）

NEXT_PUBLIC_SUPABASE_URL=

NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# RLS 用カスタム JWT 署名（Supabase ダッシュボード → Settings → API → JWT Secret）
SUPABASE_JWT_SECRET=



# LINE Login（本番連携時）
# LINE Developers の Callback URL と一致させること

LINE_CHANNEL_ID=

LINE_CHANNEL_SECRET=

LINE_CALLBACK_URL=https://tough-flow-pc-app.vercel.app/api/auth/callback/line

# LINE Messaging API（36協定アラート等の Push 通知）
# LINE Developers → Messaging API → Channel access token（長期）
LINE_CHANNEL_ACCESS_TOKEN=

# Vercel Cron 等から /api/cron/agreement-36-alerts を呼ぶ際の共有シークレット
CRON_SECRET=



# Google Drive（Phase 2）

GOOGLE_SERVICE_ACCOUNT_JSON=

GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Google Calendar（PC 現場カレンダー）
GOOGLE_CALENDAR_ID=

# OpenAI（任意。OCR は Mobile 側で使用）
OPENAI_API_KEY=

# Google Maps（PC 地図画面）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
